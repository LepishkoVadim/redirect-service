# Single EC2 instance in the default VPC running the prod docker-compose stack
# (web + nginx + postgres + redis) over HTTP on an Elastic IP.

data "aws_vpc" "default" {
  default = true
}

data "aws_subnets" "default" {
  filter {
    name   = "vpc-id"
    values = [data.aws_vpc.default.id]
  }
}

# Canonical's Ubuntu 24.04 LTS amd64 AMI, resolved from the public SSM parameter.
data "aws_ssm_parameter" "ubuntu" {
  name = "/aws/service/canonical/ubuntu/server/24.04/stable/current/amd64/hvm/ebs-gp3/ami-id"
}

resource "aws_key_pair" "this" {
  key_name   = "${var.project}-key"
  public_key = file(pathexpand(var.ssh_public_key_path))
}

resource "aws_security_group" "web" {
  name        = "${var.project}-sg"
  description = "HTTP + SSH inbound; Postgres/Redis stay in-container (not exposed)."
  vpc_id      = data.aws_vpc.default.id

  ingress {
    description = "HTTP"
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "HTTPS"
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "SSH"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = [var.ssh_ingress_cidr]
  }

  egress {
    description = "All outbound"
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

# Secrets generated by Terraform and injected into the instance .env.
resource "random_password" "secret_key" {
  length  = 64
  special = false
}

resource "random_password" "postgres" {
  length  = 32
  special = false
}

# Admin creds come from variables (var.superuser_*), not a random value — single source
# of truth so the password is known/controlled in one place (terraform.tfvars).

# Allocated before the instance so its address can be baked into ALLOWED_HOSTS.
resource "aws_eip" "this" {
  domain = "vpc"
  tags   = { Name = "${var.project}-eip" }
}

resource "aws_instance" "web" {
  ami                         = data.aws_ssm_parameter.ubuntu.value
  instance_type               = var.instance_type
  subnet_id                   = tolist(data.aws_subnets.default.ids)[0]
  vpc_security_group_ids      = [aws_security_group.web.id]
  key_name                    = aws_key_pair.this.key_name
  associate_public_ip_address = true

  root_block_device {
    volume_size = var.root_volume_gb
    volume_type = "gp3"
  }

  user_data = templatefile("${path.module}/user_data.sh.tftpl", {
    repo_url           = var.repo_url
    repo_branch        = var.repo_branch
    secret_key         = random_password.secret_key.result
    postgres_password  = random_password.postgres.result
    allowed_hosts      = "${var.domain},${aws_eip.this.public_ip},localhost,127.0.0.1"
    csrf_origin        = "http://${aws_eip.this.public_ip}"
    superuser_username = var.superuser_username
    superuser_email    = var.superuser_email
    superuser_password = var.superuser_password
  })

  # New user_data → replace the instance (fresh boot re-provisions everything).
  user_data_replace_on_change = true

  tags = { Name = "${var.project}-web" }
}

resource "aws_eip_association" "this" {
  instance_id   = aws_instance.web.id
  allocation_id = aws_eip.this.id
}
